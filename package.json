{
  "name": "sahilsal-portfolio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "build-local": "tinacms build --local --skip-indexing --skip-cloud-checks && node scripts/patch-tina-client.js && next build",
    "preview": "tinacms build --local --skip-indexing --skip-cloud-checks && node scripts/patch-tina-client.js && next build && next start",
    "start": "tinacms build && next start",
    "lint": "next lint",
    "clean": "node -e \"const fs=require('fs');['node_modules','.next','tina/__generated__'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}});console.log('cleaned')\""
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "framer-motion": "^12.23.24",
    "lenis": "1.3.18-dev.1",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "tinacms": "^2.10.1",
    "typescript": "5.5.2"
  },
  "devDependencies": {
    "@tinacms/cli": "^1.12.6",
    "@types/node": "^22.18.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.32",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16"
  }
}
